<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectApp.GpsPage"
             Title="GPS Tracking">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="📍 GPS TRACKING" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"/>

            <Border BackgroundColor="#E8F5E9" Padding="15" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Vị trí hiện tại:" FontAttributes="Bold"/>
                    <Label x:Name="LblLatitude" Text="Latitude: ---"/>
                    <Label x:Name="LblLongitude" Text="Longitude: ---"/>
                    <Label x:Name="LblAccuracy" Text="Độ chính xác: ---"/>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#FFF3E0" Padding="15" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="🎯 Nhà hàng gần nhất:" FontAttributes="Bold"/>
                    <Label x:Name="LblNearestName" Text="---"/>
                    <Label x:Name="LblDistance" Text="Khoảng cách: ---"/>
                </VerticalStackLayout>
            </Border>

            <Button x:Name="BtnStartStop" 
                    Text="Bắt đầu theo dõi"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    Clicked="OnStartStopClicked"/>

            <Label Text="📋 Log:" FontAttributes="Bold" Margin="0,10,0,0"/>
            <Border BackgroundColor="#F5F5F5" Padding="10" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="5" />
                </Border.StrokeShape>
                <ScrollView HeightRequest="200">
                    <Label x:Name="LblLog" Text="Chưa có log..."/>
                </ScrollView>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>