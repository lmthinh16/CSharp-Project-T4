<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ProjectApp"
             x:Class="ProjectApp.MainPage"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto,*">

        <!-- 1. HEADER  -->
        <Border Grid.Row="0" 
                BackgroundColor="#0D0907"
                StrokeThickness="0"
                Padding="20,30,20,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,30,30"/>
            </Border.StrokeShape>
            <Label Text="ẨM THỰC VĨNH KHÁNH" 
                   FontSize="22" 
                   FontAttributes="Bold"
                   TextColor="#FFDB58"
                   HorizontalTextAlignment="Center"/>
        </Border>

        <!-- 2. MAIN CONTENT AREA -->
        <CollectionView Grid.Row="1" 
                        x:Name="RestaurantsCollection"
                        SelectionMode="Single"
                        SelectionChanged="OnRestaurantSelected"
                        Margin="15,0">

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" 
                                 HorizontalItemSpacing="12" 
                                 VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>

           
            <CollectionView.Header>
                <VerticalStackLayout Spacing="15" Padding="0,15,0,10">

                    <!-- Map Preview Section -->
                    <Label Text="Khám Phá Bản Đồ" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50"/>
                    <Border BackgroundColor="White" HeightRequest="180" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.1" Radius="10" Offset="0,5" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMapClicked"/>
                        </Border.GestureRecognizers>
                        <local:MapPreviewControl/>
                    </Border>

                    <!-- Tours Section -->
                    <Label Text="Quán Ăn Phải Thử" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,10,0,0"/>

                    <!-- Tour 1 -->
                    <Border BackgroundColor="White" Padding="12" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTour1Clicked"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="15">
                            <Image Grid.Column="0" Source="tour_oc.jpg" Aspect="AspectFill" HeightRequest="70" WidthRequest="80">
                                <Image.Clip>
                                    <RoundRectangleGeometry CornerRadius="10" Rect="0,0,80,70"/>
                                </Image.Clip>
                            </Image>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Ốc" FontAttributes="Bold" TextColor="#2C3E50"/>
                                <Label Text="3 quán ốc ngon nổi tiếng" FontSize="12" TextColor="#7F8C8D"/>
                                <Label Text="⭐ 4.4 • 45 phút" FontSize="11" TextColor="#F39C12"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Tour 2 -->
                    <Border BackgroundColor="White" Padding="12" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTour2Clicked"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="15">
                            <Image Grid.Column="0" Source="tour_nuong.jpg" Aspect="AspectFill" HeightRequest="70" WidthRequest="80">
                                <Image.Clip>
                                    <RoundRectangleGeometry CornerRadius="10" Rect="0,0,80,70"/>
                                </Image.Clip>
                            </Image>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Đồ Nướng" FontAttributes="Bold" TextColor="#2C3E50"/>
                                <Label Text="Lẩu nướng, bò lá lốt" FontSize="12" TextColor="#7F8C8D"/>
                                <Label Text="⭐ 4.5 • 60 phút" FontSize="11" TextColor="#F39C12"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Tour 3 -->
                    <Border BackgroundColor="White" Padding="12" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTour3Clicked"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="15">
                            <Image Grid.Column="0" Source="tour_vat.jpg" Aspect="AspectFill" HeightRequest="70" WidthRequest="80">
                                <Image.Clip>
                                    <RoundRectangleGeometry CornerRadius="10" Rect="0,0,80,70"/>
                                </Image.Clip>
                            </Image>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Ăn Vặt" FontAttributes="Bold" TextColor="#2C3E50"/>
                                <Label Text="Cơm cháy, bún nướng" FontSize="12" TextColor="#7F8C8D"/>
                                <Label Text="⭐ 4.3 • 40 phút" FontSize="11" TextColor="#F39C12"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- List Title -->
                    <Label Text="Danh sách hàng quán" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,15,0,5" />
                </VerticalStackLayout>
            </CollectionView.Header>

            <!-- RESTAURANT CARD TEMPLATE -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="White" StrokeThickness="0" Margin="0,5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.1" Radius="5" Offset="0,2"/>
                        </Border.Shadow>

                        <Grid RowDefinitions="120, Auto">
                            <!-- Image Section -->
                            <Grid Grid.Row="0">
                                <Image Source="{Binding ImageUrl}" 
                                       Aspect="AspectFill" 
                                       HeightRequest="120" 
                                       HorizontalOptions="Fill" />

                                <!-- Rating Badge overlay -->
                                <Border BackgroundColor="#CC000000" Padding="6,2" HorizontalOptions="End" VerticalOptions="Start" Margin="8">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Rating, StringFormat='⭐ {0}'}" TextColor="White" FontSize="11" FontAttributes="Bold"/>
                                </Border>
                            </Grid>

                            <!-- Text Section -->
                            <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="4">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="14" MaxLines="1" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding OpenHours, StringFormat='🕐 {0}'}" FontSize="11" TextColor="#27AE60" FontAttributes="Bold"/>
                                <Label Text="{Binding Description}" FontSize="11" TextColor="#7F8C8D" MaxLines="2" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="20" Color="Transparent" />
            </CollectionView.Footer>

        </CollectionView>
    </Grid>
</ContentPage>