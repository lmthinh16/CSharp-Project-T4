<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ProjectApp"
             x:Class="ProjectApp.MainPage"
             BackgroundColor="#1A1A2E"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- 1. HEADER  -->
        <Grid Grid.Row="0"
          BackgroundColor="#16213E"
          Padding="12,10"
          ColumnDefinitions="*,40,40">
            <Label Grid.Column="0"
               Text="Ẩm Thực Vĩnh Khánh"
               FontSize="18"
               FontAttributes="Bold"
               TextColor="#E0E0F0"
               VerticalOptions="Center" />
           
        </Grid>



        <!-- 2. MAIN CONTENT AREA -->
        <CollectionView Grid.Row="2" 
                        x:Name="RestaurantsCollection"
                        SelectionMode="Single"
                        SelectionChanged="OnRestaurantSelected"
                        Margin="8,0">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.Header>
                <VerticalStackLayout Padding="8,12,8,8">
                    <Label Text="Danh sách hàng quán" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="#E0E0F0" 
                           Margin="4,0,0,8"/>
                </VerticalStackLayout>
            </CollectionView.Header>

            <!-- Item Template -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#16213E"
                            StrokeThickness="0.5"
                            Stroke="#1E3A5F"
                            StrokeShape="RoundRectangle 10"
                            Padding="10"
                            Margin="0,2">
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="12">
                            <!-- Image -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#0F3460"
                                    StrokeShape="RoundRectangle 8"
                                    HeightRequest="80"
                                    WidthRequest="80">
                                <Image Source="{Binding ImagePath}"
                                       Aspect="AspectFill"
                                       HeightRequest="80"
                                       WidthRequest="80"
                                       Margin="-1"/>
                            </Border>

                            <!-- Thông tin -->
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding Name}" 
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#FFFFFF"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"/>

                                <Label Text="{Binding OpenHours, StringFormat='🕐 {0}'}"
                                       FontSize="12"
                                       TextColor="#4EC88A"
                                       FontAttributes="Bold"/>

                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       TextColor="#A0A8C0"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"/>

                                <Label Text="{Binding Rating, StringFormat='⭐ {0}'}"
                                       FontSize="13"
                                       TextColor="#FFDB58"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>


        </CollectionView>
    </Grid>
</ContentPage>