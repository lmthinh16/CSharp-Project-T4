<?xml version="1.0" encoding="utf-8" ?>
<TabbedPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:local="clr-namespace:AppProjectT4"
            x:Class="AppProjectT4.MainTabbedPage"
            BarBackgroundColor="White"
            BarTextColor="#2C3E50"
            SelectedTabColor="#FF6B6B"
            UnselectedTabColor="#95A5A6">

    <NavigationPage Title="Trang chủ" IconImageSource="home.png">
        <x:Arguments>
            <local:MainPage/>
        </x:Arguments>
    </NavigationPage>

    <NavigationPage Title="Bản đồ" IconImageSource="map.png">
        <x:Arguments>
            <local:MapPage/>
        </x:Arguments>
    </NavigationPage>

    

</TabbedPage>