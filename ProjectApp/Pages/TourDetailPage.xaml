<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectApp.Pages.TourDetailPage"
             BackgroundColor="#1A1A2E"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="#0D0907" Padding="12,20,12,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Text="←" TextColor="#FFDB58" BackgroundColor="Transparent"
                    HorizontalOptions="Start" Clicked="OnBackClicked"/>
            <VerticalStackLayout Grid.Row="1" Spacing="4" HorizontalOptions="Center">
                <Label x:Name="TourTitleLabel" FontSize="22" FontAttributes="Bold"
                       TextColor="White" HorizontalTextAlignment="Center"/>
                <Label x:Name="TourDescLabel" FontSize="13" TextColor="#FFDB58"
                       HorizontalTextAlignment="Center"/>
                <Label x:Name="TourMetaLabel" FontSize="12" TextColor="#FFDB58"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Restaurant list -->
        <CollectionView Grid.Row="1" x:Name="RestaurantsCollection"
                        SelectionMode="None" Margin="14,8">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:Object">
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Margin="0,6" Padding="0">
                        <Grid RowDefinitions="140,Auto">
                            <!-- Image area -->
                            <Border Grid.Row="0" BackgroundColor="#FFE5E5" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16,16,0,0">
                                <Grid>
                                    <Label Text="🍜" FontSize="60" Opacity="0.25"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Border BackgroundColor="#0D0907" StrokeThickness="0"
                                            Padding="8,5" HorizontalOptions="End" VerticalOptions="Start"
                                            Margin="10" StrokeShape="RoundRectangle 12">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="⭐" FontSize="13"/>
                                            <Label Text="{Binding Rating}" FontSize="13"
                                                   FontAttributes="Bold" TextColor="White"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- Info area -->
                            <VerticalStackLayout Grid.Row="1" Padding="14,12" Spacing="6">
                                <Label Text="{Binding Name}" FontSize="17" FontAttributes="Bold"
                                       TextColor="#2C3E50"/>
                                <Label Text="{Binding Description}" FontSize="12" TextColor="#7F8C8D"
                                       MaxLines="2" LineBreakMode="TailTruncation"/>
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="🕐" FontSize="12"/>
                                    <Label Text="{Binding OpenHours}" FontSize="12"
                                           TextColor="#27AE60" FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
