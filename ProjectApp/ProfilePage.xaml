<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectApp.ProfilePage"
             BackgroundColor="#1A1A2E"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="👤 Cá Nhân"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="#E0E0F0" HorizontalOptions="Center"
                   Margin="0,10,0,0"/>

            <!-- Avatar + user info -->
            <Border BackgroundColor="#0D1B2A" Stroke="#1E3A5F" StrokeThickness="0.5"
                    StrokeShape="RoundRectangle 14" Padding="18,16">
                <Grid ColumnDefinitions="72,*,Auto">

                    <!-- Avatar circle -->
                    <Border Grid.Column="0" BackgroundColor="#1E6FA8"
                            StrokeShape="RoundRectangle 36"
                            WidthRequest="72" HeightRequest="72">
                        <Label x:Name="LblInitial" Text="G" FontSize="30"
                               FontAttributes="Bold" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Name + role -->
                    <VerticalStackLayout Grid.Column="1" Spacing="4"
                                         VerticalOptions="Center" Margin="12,0">
                        <Label x:Name="LblDisplayName" Text="Du khách"
                               FontSize="17" FontAttributes="Bold" TextColor="#E0E8FF"/>
                        <Label x:Name="LblUsername" Text="Khách ẩn danh"
                               FontSize="12" TextColor="#6A7A9A"/>
                        <Label x:Name="LblRole" Text="👤 Khách"
                               FontSize="12" TextColor="#4EA5D9"/>
                    </VerticalStackLayout>

                    <!-- Logout button -->
                    <Button Grid.Column="2" Text="↩"
                            FontSize="18" TextColor="#E05555"
                            BackgroundColor="Transparent"
                            Padding="8,0" VerticalOptions="Center"
                            Clicked="OnLogoutClicked"/>
                </Grid>
            </Border>

            <!-- Stats -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Border Grid.Column="0" BackgroundColor="#0D1B2A"
                        Stroke="#1E3A5F" StrokeThickness="0.5"
                        StrokeShape="RoundRectangle 10" Padding="12">
                    <VerticalStackLayout Spacing="3">
                        <Label x:Name="LblVisitCount" Text="0"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#4EA5D9" HorizontalOptions="Center"/>
                        <Label Text="Đã ghé" FontSize="11"
                               TextColor="#6A7A9A" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" BackgroundColor="#0D1B2A"
                        Stroke="#1E3A5F" StrokeThickness="0.5"
                        StrokeShape="RoundRectangle 10" Padding="12">
                    <VerticalStackLayout Spacing="3">
                        <Label x:Name="LblTourCount" Text="0"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#4EC88A" HorizontalOptions="Center"/>
                        <Label Text="Tours" FontSize="11"
                               TextColor="#6A7A9A" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2" BackgroundColor="#0D1B2A"
                        Stroke="#1E3A5F" StrokeThickness="0.5"
                        StrokeShape="RoundRectangle 10" Padding="12">
                    <VerticalStackLayout Spacing="3">
                        <Label x:Name="LblFavoriteCount" Text="0"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#FFDB58" HorizontalOptions="Center"/>
                        <Label Text="Yêu thích" FontSize="11"
                               TextColor="#6A7A9A" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Menu -->
            <Border BackgroundColor="#0D1B2A" Stroke="#1E3A5F" StrokeThickness="0.5"
                    StrokeShape="RoundRectangle 12" Padding="4,0">
                <VerticalStackLayout>

                    <Grid Padding="14,14" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="📜 Lịch sử ghé thăm"
                               FontSize="14" TextColor="#E0E0F0"/>
                        <Label Grid.Column="1" Text="›" FontSize="18" TextColor="#4EA5D9"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnVisitHistoryClicked"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                    <BoxView HeightRequest="0.5" Color="#1E3A5F" Margin="14,0"/>

                    <Grid Padding="14,14" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="⭐ Quán yêu thích"
                               FontSize="14" TextColor="#E0E0F0"/>
                        <Label Grid.Column="1" Text="›" FontSize="18" TextColor="#4EA5D9"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFavoritesClicked"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                    <BoxView HeightRequest="0.5" Color="#1E3A5F" Margin="14,0"/>

                    <Grid Padding="14,14" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="⚙️ Cài đặt" FontSize="14" TextColor="#E0E0F0"/>
                        <Label Grid.Column="1" Text="›" FontSize="18" TextColor="#4EA5D9"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Label Text="VinhKhanhTour v1.0 · Ẩm thực Vĩnh Khánh Q4"
                   FontSize="11" TextColor="#2A3A5A"
                   HorizontalOptions="Center" Margin="0,8,0,24"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
