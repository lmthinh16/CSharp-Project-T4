<?xml version="1.0" encoding="utf-8" ?>
<!--
  MapPage.xaml — ProjectAppv3
  Thay thế file MapPage.xaml cũ.
  Dùng kèm MapPage.xaml.cs (thay thế) và MapPage.cs (xoá file này đi nếu còn tồn tại).
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectApp.MapPage"
             Title="Bản đồ"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F172A">

    <Grid>

        <!-- ── 1. WebView bản đồ Leaflet (full screen) ─────────────── -->
        <WebView x:Name="mapWebView"
                 ZIndex="0"/>

        <!-- ── 2. Thanh thông tin tuyến đường (top) ────────────────── -->
        <Frame x:Name="routeInfoBar"
               IsVisible="False"
               Margin="12,52,12,0"
               VerticalOptions="Start"
               Padding="12,10"
               CornerRadius="14"
               BackgroundColor="White"
               HasShadow="True"
               ZIndex="10">
            <Grid ColumnDefinitions="*,36">
                <Label x:Name="routeInfoLabel"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#1E293B"
                       VerticalOptions="Center"/>
                <ImageButton Grid.Column="1"
                             Source="close_icon"
                             WidthRequest="28" HeightRequest="28"
                             CornerRadius="14"
                             BackgroundColor="#F1F5F9"
                             Clicked="OnRouteInfoClose"/>
            </Grid>
        </Frame>

        <!-- ── 3. FABs (phải, giữa màn hình) ──────────────────────── -->
        <VerticalStackLayout HorizontalOptions="End"
                             VerticalOptions="Center"
                             Margin="0,0,12,0"
                             Spacing="10"
                             ZIndex="10">

            <Button Text="◎"
                    FontSize="22"
                    TextColor="#2563EB"
                    BackgroundColor="White"
                    CornerRadius="26"
                    WidthRequest="52" HeightRequest="52"
                    Padding="0"
                    Clicked="OnMyLocationClicked">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity=".18"/>
                </Button.Shadow>
            </Button>

            <Button x:Name="routeBtn"
                    Text="🗺 Dẫn đường"
                    FontSize="12"
                    FontAttributes="Bold"
                    TextColor="White"
                    BackgroundColor="#2563EB"
                    CornerRadius="26"
                    Padding="14,0"
                    HeightRequest="52"
                    Clicked="OnRouteBtnClicked">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity=".22"/>
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

        <!-- ── 4. Bottom sheet POI (ẩn mặc định, slide lên khi vào geofence) -->
        <Frame x:Name="bottomSheet"
               IsVisible="False"
               TranslationY="320"
               VerticalOptions="End"
               Margin="0"
               Padding="0"
               CornerRadius="22"
               BackgroundColor="White"
               HasShadow="True"
               ZIndex="20">

            <Grid RowDefinitions="Auto,Auto,Auto"
                  Padding="20,14,20,36">

                <!-- Handle -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                    <BoxView HorizontalOptions="Center"
                             VerticalOptions="Center"
                             WidthRequest="36" HeightRequest="4"
                             CornerRadius="2"
                             Color="#E2E8F0"/>
                    <Button Grid.Column="1"
                            Text="✕"
                            FontSize="16"
                            TextColor="#94A3B8"
                            BackgroundColor="Transparent"
                            WidthRequest="36" HeightRequest="36"
                            Padding="0"
                            Clicked="OnBottomSheetClose"/>
                </Grid>

                <!-- POI info -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="12"
                      Margin="0,0,0,16">
                    <Label x:Name="poiEmojiLabel"
                           FontSize="40"
                           VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center"
                                         Spacing="4">
                        <Label x:Name="poiNameLabel"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="#0F172A"
                               LineBreakMode="TailTruncation"/>
                        <Label x:Name="poiDescLabel"
                               FontSize="13"
                               TextColor="#64748B"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Action buttons -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">

                    <Button Grid.Column="0"
                            Text="🔉 Audio"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="#2563EB"
                            BackgroundColor="#EFF6FF"
                            CornerRadius="14"
                            HeightRequest="46"
                            Clicked="OnAudioBtnClicked"/>

                    <Button Grid.Column="1"
                            Text="🗺 Đường đi"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="#334155"
                            BackgroundColor="#F1F5F9"
                            CornerRadius="14"
                            HeightRequest="46"
                            Clicked="OnRouteBtnClicked"/>

                    <Button Grid.Column="2"
                            Text="ℹ Chi tiết"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="White"
                            BackgroundColor="#2563EB"
                            CornerRadius="14"
                            HeightRequest="46"
                            Clicked="OnPoiDetailClicked"/>
                </Grid>
            </Grid>
        </Frame>

    </Grid>
</ContentPage>
