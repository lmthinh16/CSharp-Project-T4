<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjectApp.Pages.AudioPage"
             BackgroundColor="#1A1A2E"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Top nav -->
        <Grid Grid.Row="0" BackgroundColor="#16213E" Padding="12,8" ColumnDefinitions="*,Auto">
            <Label Grid.Column="0" Text="🎵 Hàng chờ Audio"
                   FontSize="16" FontAttributes="Bold" TextColor="#E0E0F0" VerticalOptions="Center"/>
            <Button Grid.Column="1" x:Name="BtnClear" Text="Xóa tất cả"
                    FontSize="12" TextColor="#E05555" BackgroundColor="Transparent"
                    IsVisible="False" Clicked="OnClearClicked"/>
        </Grid>

        <!-- Now Playing card -->
        <Border Grid.Row="1" x:Name="NowPlayingCard"
                BackgroundColor="#0D1B2A" Stroke="#1E6FA8" StrokeThickness="1"
                StrokeShape="RoundRectangle 10" Margin="12,8" Padding="14,12" IsVisible="False">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="▶ Đang phát" FontSize="10" TextColor="#4EA5D9" FontAttributes="Bold"/>
                    <Label x:Name="LblCurrentTitle" FontSize="14" FontAttributes="Bold" TextColor="#E0E8FF"/>
                    <Label x:Name="LblCurrentDuration" FontSize="11" TextColor="#6A7A9A"/>
                </VerticalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                    <Button Text="⏭" FontSize="18" TextColor="#8899AA"
                            BackgroundColor="Transparent" Clicked="OnSkipClicked"/>
                    <Button x:Name="BtnPlayPause" Text="⏸" FontSize="18"
                            BackgroundColor="#1E6FA8" TextColor="White"
                            CornerRadius="20" WidthRequest="40" HeightRequest="40"
                            Padding="0" Clicked="OnPlayPauseClicked"/>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Queue list / Empty state -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <VerticalStackLayout x:Name="EmptyState"
                                 HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                <Label Text="🎵" FontSize="48" HorizontalOptions="Center"/>
                <Label Text="Hàng chờ trống" FontSize="16"
                       TextColor="#3A4A6A" HorizontalOptions="Center"/>
                <Label Text="Chọn nhà hàng → nhấn + để thêm audio"
                       FontSize="12" TextColor="#3A4A6A"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="20,0"/>
            </VerticalStackLayout>

            <!-- Queue list -->
            <CollectionView x:Name="QueueCollection" SelectionMode="None"
                            Margin="12,0" IsVisible="False">
                <CollectionView.Header>
                    <Label Text="Tiếp theo" FontSize="12" FontAttributes="Bold"
                           TextColor="#4EA5D9" Margin="0,8,0,4"/>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Border BackgroundColor="#16213E" Stroke="#2A3A5A" StrokeThickness="0.5"
                                StrokeShape="RoundRectangle 8" Padding="12,10" Margin="0,2">
                            <Grid ColumnDefinitions="32,*">
                                <Border Grid.Column="0" BackgroundColor="#0F3460"
                                        StrokeShape="RoundRectangle 16"
                                        WidthRequest="28" HeightRequest="28">
                                    <Label Text="🎵" FontSize="13"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="10,0">
                                    <Label Text="{Binding Title}" FontSize="13" TextColor="#C0D0E8"/>
                                    <Label Text="{Binding DurationDisplay}" FontSize="10" TextColor="#6A7A9A"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

    </Grid>
</ContentPage>
