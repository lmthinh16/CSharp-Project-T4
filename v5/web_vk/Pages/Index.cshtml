@page
@model RestaurantsModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vĩnh Khánh Food Tour</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Mulish:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --gold: #c9a84c;
            --gold-light: #e8c97a;
            --dark: #0f1117;
            --dark-2: #181c27;
            --dark-3: #222840;
            --text: #e8e6df;
            --text-muted: #8a8a9a;
        }

        html, body {
            height: 100%;
            background: var(--dark);
            color: var(--text);
            font-family: 'Mulish', sans-serif;
            overflow-x: hidden;
        }

        /* ── Background ── */
        .bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(201,168,76,.18) 0%, transparent 70%), radial-gradient(ellipse 50% 50% at 10% 80%, rgba(201,168,76,.08) 0%, transparent 60%), var(--dark);
        }

            .bg::after {
                content: '';
                position: absolute;
                inset: 0;
                background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c9a84c' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            }

        /* ── Nav ── */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            padding: 22px 48px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: linear-gradient(to bottom, rgba(15,17,23,.9), transparent);
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--gold);
            letter-spacing: .04em;
        }

            .logo span {
                color: var(--text);
                font-weight: 400;
            }

        /* ── Hero ── */
        .hero {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0 24px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid rgba(201,168,76,.4);
            border-radius: 99px;
            padding: 6px 18px;
            font-size: 12px;
            font-weight: 600;
            color: var(--gold-light);
            letter-spacing: .12em;
            text-transform: uppercase;
            margin-bottom: 32px;
            animation: fadeUp .8s ease both;
        }

            .badge::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: var(--gold);
                box-shadow: 0 0 6px var(--gold);
            }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(42px, 7vw, 90px);
            font-weight: 900;
            line-height: 1.08;
            letter-spacing: -.02em;
            margin-bottom: 24px;
            animation: fadeUp .8s .15s ease both;
        }

            h1 em {
                font-style: normal;
                background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .subtitle {
            font-size: 18px;
            font-weight: 300;
            color: var(--text-muted);
            max-width: 520px;
            line-height: 1.7;
            margin-bottom: 52px;
            animation: fadeUp .8s .3s ease both;
        }

        /* ── Login Button ── */
        .cta-wrap {
            animation: fadeUp .8s .45s ease both;
        }

        .btn-login {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            background: var(--gold);
            color: var(--dark);
            font-family: 'Mulish', sans-serif;
            font-size: 15px;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            padding: 18px 44px;
            border-radius: 4px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: all .25s ease;
            box-shadow: 0 8px 32px rgba(201,168,76,.3);
        }

            .btn-login:hover {
                background: var(--gold-light);
                transform: translateY(-2px);
                box-shadow: 0 12px 40px rgba(201,168,76,.45);
            }

            .btn-login svg {
                width: 18px;
                height: 18px;
            }

        /* ── Divider line ── */
        .divider {
            width: 80px;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--gold), transparent);
            margin: 60px auto 0;
            animation: fadeUp .8s .6s ease both;
        }

        /* ── Features ── */
        .features {
            position: relative;
            z-index: 1;
            display: flex;
            gap: 0;
            max-width: 900px;
            margin: 0 auto;
            padding: 60px 24px 100px;
            animation: fadeUp .8s .75s ease both;
        }

        .feat {
            flex: 1;
            text-align: center;
            padding: 32px 24px;
            border-top: 1px solid rgba(201,168,76,.15);
        }

            .feat:not(:last-child) {
                border-right: 1px solid rgba(201,168,76,.1);
            }

        .feat-icon {
            font-size: 28px;
            margin-bottom: 14px;
        }

        .feat-title {
            font-family: 'Playfair Display', serif;
            font-size: 16px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }

        .feat-desc {
            font-size: 13px;
            color: var(--text-muted);
            line-height: 1.6;
        }

        /* ── Modal Overlay ── */
        .overlay {
            position: fixed;
            inset: 0;
            z-index: 200;
            background: rgba(10,12,18,.85);
            backdrop-filter: blur(6px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .3s ease;
        }

            .overlay.open {
                opacity: 1;
                pointer-events: all;
            }

        .modal {
            background: var(--dark-2);
            border: 1px solid rgba(201,168,76,.2);
            border-radius: 16px;
            padding: 48px 40px;
            width: 100%;
            max-width: 460px;
            text-align: center;
            transform: translateY(24px) scale(.97);
            transition: transform .35s cubic-bezier(.34,1.56,.64,1);
        }

        .overlay.open .modal {
            transform: translateY(0) scale(1);
        }

        .modal-title {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }

        .modal-sub {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 36px;
        }

        .role-cards {
            display: flex;
            gap: 16px;
            margin-bottom: 28px;
        }

        .role-card {
            flex: 1;
            padding: 24px 16px;
            border: 1.5px solid rgba(201,168,76,.2);
            border-radius: 12px;
            cursor: pointer;
            text-decoration: none;
            transition: all .2s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

            .role-card:hover {
                border-color: var(--gold);
                background: rgba(201,168,76,.07);
                transform: translateY(-3px);
            }

            .role-card.selected {
                border-color: var(--gold);
                background: rgba(201,168,76,.1);
            }

        .role-icon {
            font-size: 32px;
        }

        .role-name {
            font-family: 'Mulish', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
        }

        .role-desc {
            font-size: 12px;
            color: var(--text-muted);
        }

        .btn-confirm {
            width: 100%;
            padding: 14px;
            background: var(--gold);
            color: var(--dark);
            font-family: 'Mulish', sans-serif;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all .2s ease;
            opacity: .4;
            pointer-events: none;
        }

            .btn-confirm.active {
                opacity: 1;
                pointer-events: all;
            }

                .btn-confirm.active:hover {
                    background: var(--gold-light);
                }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 16px;
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 20px;
            transition: color .2s;
        }

            .modal-close:hover {
                color: var(--text);
            }

        .modal {
            position: relative;
        }

        /* ── Footer ── */
        footer {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 28px;
            font-size: 12px;
            color: var(--text-muted);
            border-top: 1px solid rgba(255,255,255,.05);
        }

        /* ── Animations ── */
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(28px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="bg"></div>

    <nav>
        <div class="logo">Vĩnh <span>Khánh</span></div>
    </nav>

    <!-- HERO -->
    <section class="hero">
        <div class="badge">🍜 Khám phá ẩm thực địa phương</div>

        <h1>Food Tour<br /><em>Vĩnh Khánh</em></h1>

        <p class="subtitle">
            Trải nghiệm hành trình ẩm thực độc đáo — nghe thuyết minh tự động,
            khám phá từng địa điểm ăn uống đặc sắc nhất tại Vĩnh Khánh.
        </p>

        <div class="cta-wrap">
            <button class="btn-login" onclick="openModal()">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M18 12H9m0 0l3-3m-3 3l3 3" />
                </svg>
                Đăng nhập
            </button>
        </div>

        <div class="divider"></div>
    </section>

    <!-- FEATURES -->
    <div class="features">
        <div class="feat">
            <div class="feat-icon">🎧</div>
            <div class="feat-title">Thuyết minh tự động</div>
            <div class="feat-desc">Giọng đọc AI tiếng Việt tự nhiên cho mỗi địa điểm</div>
        </div>
        <div class="feat">
            <div class="feat-icon">📍</div>
            <div class="feat-title">Bản đồ địa điểm</div>
            <div class="feat-desc">Dễ dàng tìm đường đến các quán ăn đặc sắc</div>
        </div>
        <div class="feat">
            <div class="feat-icon">🌐</div>
            <div class="feat-title">Đa ngôn ngữ</div>
            <div class="feat-desc">Hỗ trợ khách trong nước và quốc tế</div>
        </div>
    </div>

    <footer>© 2026 Vĩnh Khánh Food Tour. Đồ án C#.</footer>

    <!-- MODAL CHỌN VAI TRÒ -->
    <div class="overlay" id="overlay" onclick="handleOverlayClick(event)">
        <div class="modal">
            <button class="modal-close" onclick="closeModal()">✕</button>
            <div class="modal-title">Chào mừng trở lại</div>
           <!-- <div class="modal-sub">Bạn đăng nhập với tư cách nào?</div> -->

            <div class="role-cards">
                <div class="role-card" id="card-admin" onclick="selectRole('admin')">
                    <div class="role-icon">🛡️</div>
                    <div class="role-name">Admin</div>
                    <div class="role-desc">Quản trị hệ thống</div>
                </div>
               
                <div class="role-card" id="card-owner" onclick="selectRole('owner')">
                    <div class="role-icon">🍽️</div>
                    <div class="role-name">Chủ nhà hàng</div>
                    <div class="role-desc">Quản lý địa điểm</div>
                </div>
               
            </div>

            <button class="btn-confirm" id="btn-confirm" onclick="goLogin()">
                Tiếp tục →
            </button>
        </div>
    </div>

    <script>
        let selectedRole = null;

        function openModal() {
            document.getElementById('overlay').classList.add('open');
        }

        function closeModal() {
            document.getElementById('overlay').classList.remove('open');
            resetModal();
        }

        function handleOverlayClick(e) {
            if (e.target === document.getElementById('overlay')) closeModal();
        }

        function selectRole(role) {
            selectedRole = role;
            document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
            document.getElementById('card-' + role).classList.add('selected');
            document.getElementById('btn-confirm').classList.add('active');
        }

        function resetModal() {
            selectedRole = null;
            document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
            document.getElementById('btn-confirm').classList.remove('active');
        }

        function goLogin() {
            if (!selectedRole) return;
            // Đưa role vào query string để trang Login biết
            window.location.href = '/Login?role=' + selectedRole;
        }
    </script>
</body>
</html>
