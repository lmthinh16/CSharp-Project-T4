@page
@model web_vk.Pages.AudioModel
@{
    Layout = null;
    var username = HttpContext.Session.GetString("user") ?? "Admin";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản lý Nội dung Thuyết minh – Vĩnh Khánh</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        /* GIỮ NGUYÊN PHẦN CSS CỦA BẠN */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --sidebar-bg: #13151f;
            --sidebar-w: 260px;
            --accent: #c9a84c;
            --accent-hover: #b8923e;
            --text-muted: #8a8a9a;
            --header-h: 64px;
            --radius: 12px;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background: #0f1117;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            color: #fff;
            display: flex;
            flex-direction: column;
            height: 100vh;
            flex-shrink: 0;
        }

        .sidebar-brand {
            padding: 22px 20px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(201,168,76,.12);
        }

        .brand-icon {
            width: 38px;
            height: 38px;
            background: var(--accent);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .brand-text .name {
            font-weight: 700;
            font-size: 15px;
        }

        .brand-text .role {
            font-size: 10px;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .nav-section {
            padding: 20px 12px 6px;
        }

        .nav-label {
            font-size: 10px;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: 0 10px 8px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            color: #a89878;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: background .15s, color .15s;
        }

            .nav-link:hover {
                background: rgba(255,255,255,.07);
                color: #fff;
            }

            .nav-link.active {
                background: var(--accent);
                color: #fff;
            }

        .nav-icon {
            font-size: 16px;
            width: 20px;
            text-align: center;
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 12px;
            border-top: 1px solid rgba(201,168,76,.12);
        }

        .user-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            border-radius: 8px;
            background: rgba(255,255,255,.05);
            margin-bottom: 8px;
        }

        .avatar {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            background: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info .uname {
            font-size: 13px;
            font-weight: 600;
        }

        .user-info .urole {
            font-size: 11px;
            color: var(--text-muted);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            padding: 10px 12px;
            border-radius: 8px;
            background: rgba(255,255,255,.05);
            border: none;
            cursor: pointer;
            color: #c3cde6;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            transition: background .15s;
        }

            .logout-btn:hover {
                background: rgba(255,255,255,.1);
                color: #fff;
            }

        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .topbar {
            height: var(--header-h);
            background: #13151f;
            border-bottom: 1px solid rgba(201,168,76,.15);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            flex-shrink: 0;
        }

            .topbar h1 {
                font-size: 18px;
                font-weight: 700;
                color: #e8e6df;
            }

        .status-pill {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 13px;
            font-weight: 500;
            color: #16a34a;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 0 3px rgba(34,197,94,.2);
        }

        .content {
            flex: 1;
            overflow-y: auto;
            padding: 24px 28px;
        }

        .toast {
            padding: 12px 18px;
            border-radius: 9px;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .toast.success {
                background: rgba(34,197,94,.1);
                border: 1px solid rgba(34,197,94,.3);
                color: #16a34a;
            }

            .toast.error {
                background: rgba(239,68,68,.1);
                border: 1px solid rgba(239,68,68,.3);
                color: #dc2626;
            }

        .tts-card {
            background: #13151f;
            border-radius: var(--radius);
            padding: 26px 28px;
            margin-bottom: 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,.3);
        }

            .tts-card h3 {
                font-size: 15px;
                font-weight: 700;
                color: #e8e6df;
                margin-bottom: 20px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

        .tts-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 14px;
        }

        .form-group label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: .07em;
            margin-bottom: 6px;
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 9px 12px;
            border-radius: 8px;
            border: 1.5px solid rgba(201,168,76,.2);
            font-size: 13px;
            font-family: inherit;
            outline: none;
            color: #e8e6df;
            transition: border-color .15s;
            background: #13151f;
            resize: vertical;
        }

            .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
                border-color: var(--accent);
            }

        .char-count {
            font-size: 11px;
            color: var(--text-muted);
            text-align: right;
            margin-top: 4px;
        }

        .btn-generate {
            width: 100%;
            padding: 12px;
            border-radius: 9px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-size: 14px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 14px rgba(201,168,76,.35);
            transition: background .15s, transform .1s;
            margin-top: 6px;
        }

            .btn-generate:hover {
                background: var(--accent-hover);
                transform: translateY(-1px);
            }

            .btn-generate:disabled {
                opacity: .6;
                cursor: not-allowed;
                transform: none;
            }

        .spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
            display: none;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .section-title {
            font-size: 15px;
            font-weight: 700;
            color: #e8e6df;
        }

        .count-badge {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            background: rgba(201,168,76,.1);
            padding: 3px 10px;
            border-radius: 99px;
        }

        .audio-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .audio-card {
            background: #13151f;
            border-radius: var(--radius);
            padding: 18px 22px;
            box-shadow: 0 1px 4px rgba(0,0,0,.3);
            transition: box-shadow .2s;
        }

            .audio-card:hover {
                box-shadow: 0 4px 16px rgba(0,0,0,.1);
            }

        .audio-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 12px;
        }

        .audio-left {
            display: flex;
            align-items: flex-start;
            gap: 14px;
        }

        .audio-thumb {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: rgba(201,168,76,.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .audio-title {
            font-size: 14px;
            font-weight: 600;
            color: #e8e6df;
            margin-bottom: 3px;
        }

        .audio-meta {
            font-size: 12px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .meta-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            font-weight: 600;
            padding: 2px 9px;
            border-radius: 99px;
        }

            .meta-tag.blue {
                background: rgba(201,168,76,.1);
                color: var(--accent);
            }

            .meta-tag.gray {
                background: rgba(139,154,184,.12);
                color: var(--text-muted);
            }

            .meta-tag.green {
                background: rgba(34,197,94,.1);
                color: #16a34a;
            }

        .text-preview {
            font-size: 12px;
            color: #a89878;
            background: rgba(255,255,255,.04);
            border-radius: 7px;
            padding: 10px 12px;
            margin-bottom: 12px;
            border-left: 3px solid var(--accent);
            line-height: 1.6;
        }

        .audio-bottom {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            flex-wrap: wrap;
            gap: 10px;
        }

        .audio-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .assign-form {
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .assign-form select {
                padding: 6px 10px;
                border-radius: 7px;
                border: 1.5px solid rgba(201,168,76,.2);
                font-size: 12px;
                font-family: inherit;
                outline: none;
                color: #e8e6df;
                transition: border-color .15s;
            }

                .assign-form select:focus {
                    border-color: var(--accent);
                }

        .btn-assign {
            padding: 6px 14px;
            border-radius: 7px;
            border: none;
            background: rgba(201,168,76,.1);
            color: var(--accent);
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s;
        }

            .btn-assign:hover {
                background: rgba(201,168,76,.2);
            }

        .btn-delete {
            padding: 6px 14px;
            border-radius: 7px;
            border: none;
            background: rgba(239,68,68,.08);
            color: #dc2626;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s;
        }

            .btn-delete:hover {
                background: rgba(239,68,68,.15);
            }

        .empty {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

            .empty .empty-icon {
                font-size: 48px;
                margin-bottom: 12px;
                opacity: .4;
            }

            .empty p {
                font-size: 14px;
            }

        .btn-preview {
            background: #3b82f6 !important;
            box-shadow: 0 4px 14px rgba(59, 130, 246, 0.3) !important;
        }

            .btn-preview:hover {
                background: #2563eb !important;
            }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">✈</div>
            <div class="brand-text">
                <div class="name">Vĩnh Khánh</div>
                <div class="role">Admin Dashboard</div>
            </div>
        </div>
        <div class="nav-section">
            <div class="nav-label">Tổng quan</div>
            <a href="/Dashboard" class="nav-link"><span class="nav-icon">⊞</span> Tổng quan</a>
        </div>
        <div class="nav-section">
            <div class="nav-label">Quản lý nội dung</div>
            <a href="/Restaurants" class="nav-link"><span class="nav-icon">📍</span> Quản lý địa điểm</a>
            <a href="/Tours" class="nav-link"><span class="nav-icon">🔀</span> Quản lý Tour</a>
            <a href="/Audio" class="nav-link active"><span class="nav-icon">🎧</span> Quản lý Audio</a>
            <a href="/Translations" class="nav-link">
                <span class="nav-icon">🌐</span> Bản dịch đa ngữ
            </a>
        </div>
        <div class="nav-section">
            <div class="nav-label">Người dùng</div>
            <a href="/UserManager" class="nav-link">
                <span class="nav-icon">👥</span> Quản lý User
            </a>
        </div>
        <div class="sidebar-footer">
            <div class="user-row">
                <div class="avatar">@username[0].ToString().ToUpper()</div>
                <div class="user-info">
                    <div class="uname">@username</div>
                    <div class="urole">Super Admin</div>
                </div>
            </div>
            <a href="/Login" class="logout-btn">
                <span>↪</span> Đăng xuất
            </a>
        </div>
    </aside>

    <div class="main">
        <header class="topbar">
            <h1>Quản lý Thuyết minh (Offline TTS)</h1>
            <div class="status-pill">
                <div class="status-dot"></div>
                Hệ thống đang hoạt động
            </div>
        </header>

        <div class="content">

            @if (TempData["Success"] != null)
            {
                <div class="toast success">✅ @TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="toast error">⚠ @TempData["Error"]</div>
            }

            <div class="tts-card">
                <h3>🎙 Soạn thảo kịch bản thuyết minh</h3>
                <form method="post" asp-page-handler="Generate" id="ttsForm">
                    <input type="hidden" name="id" value="@ViewData["EditId"]" />

                    <div class="tts-grid">
                        <div class="form-group">
                            <label>Tiêu đề thuyết minh</label>
                            <input name="title" id="titleInput" placeholder="Nhập tiêu đề..." value="@ViewData["EditTitle"]" />
                        </div>
                        <div class="form-group">
                            <label>Gắn vào địa điểm</label>
                            <select name="restaurantId" id="resSelect">
                                <option value="0">-- Chưa gắn --</option>
                                @foreach (var r in Model.Restaurants)
                                {
                                    <option value="@r.Id" selected="@(ViewData["EditResId"]?.ToString() == r.Id.ToString())">@r.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Ngôn ngữ thuyết minh</label>
                            <select name="languageCode" id="languageSelect">
                                <option value="vi-VN" selected='@(ViewData["EditLang"]?.ToString() == "vi-VN")'>Tiếng Việt 🇻🇳</option>
                                <option value="en-US" selected='@(ViewData["EditLang"]?.ToString() == "en-US")'>Tiếng Anh 🇺🇸</option>
                                <option value="zh-CN" selected='@(ViewData["EditLang"]?.ToString() == "zh-CN")'>Tiếng Trung 🇨🇳</option>
                                <option value="ja-JP" selected='@(ViewData["EditLang"]?.ToString() == "ja-JP")'>Tiếng Nhật 🇯🇵</option>
                                <option value="ko-KR" selected='@(ViewData["EditLang"]?.ToString() == "ko-KR")'>Tiếng Hàn 🇰🇷</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group" style="margin-bottom:6px">
                        <label>Nội dung thuyết minh <span style="color:#dc2626">*</span></label>
                        <textarea name="text" id="textInput" rows="5"
                                  placeholder="Nhập nội dung văn bản. App di động sẽ tự động đọc nội dung này khi khách đến gần địa điểm..."
                                  maxlength="5000" oninput="updateCount(this)">@ViewData["EditText"]</textarea>
                        <div class="char-count"><span id="charCount">0</span> / 5000 ký tự</div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 10px;">
                        <button type="button" class="btn-generate btn-preview" onclick="previewText('textInput', false, 'languageSelect')">
                            <span>🔊 Nghe thử (Trình duyệt)</span>
                        </button>
                        <button type="button" class="btn-generate" style="background: #64748b;" onclick="stopSpeaking()">
                            <span>⏹ Dừng</span>
                        </button>
                        <button type="submit" class="btn-generate" id="genBtn">
                            <div class="spinner" id="spinner"></div>
                            <span id="genText">@(ViewData["IsEditMode"] != null ? "💾 Cập nhật kịch bản" : "💾 Lưu kịch bản mới")</span>
                        </button>
                    </div>
                    @if (ViewData["IsEditMode"] != null)
                    {
                        <a href="/Audio" style="display: block; text-align: center; margin-top: 10px; font-size: 12px; color: var(--text-muted); text-decoration: none;">✕ Hủy chế độ sửa (Tạo mới)</a>
                    }
                </form>
            </div>

            <div class="section-header">
                <div class="section-title">Danh sách kịch bản đã lưu</div>
                <span class="count-badge">@Model.AudioList.Count kịch bản</span>
            </div>

            @if (!Model.AudioList.Any())
            {
                <div class="empty">
                    <div class="empty-icon">📝</div>
                    <p>Chưa có kịch bản nào. Hãy soạn kịch bản đầu tiên!</p>
                </div>
            }
            else
            {
                <div class="audio-list">
                    @foreach (var a in Model.AudioList)
                    {
                        <div class="audio-card">
                            <div class="audio-top">
                                <div class="audio-left">
                                    <div class="audio-thumb">📄</div>
                                    <div>
                                        <div class="audio-title">@a.Title</div>
                                        <div class="audio-meta">
                                            <span>@a.UploadedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                            <span class="meta-tag blue">🌐 @a.LanguageCode</span>
                                            @if (a.Restaurant != null)
                                            {
                                                <span class="meta-tag green">📍 @a.Restaurant.Name</span>
                                            }
                                            else
                                            {
                                                <span class="meta-tag gray">Chưa gắn địa điểm</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(a.TextContent))
                            {
                                <div class="text-preview" id="preview-@a.Id">
                                    "@a.TextContent"
                                </div>
                            }

                            <div class="audio-bottom">
                                <div class="audio-actions">
                                    <button type="button" class="btn-assign" onclick="previewText('preview-@a.Id', true, null, '@a.LanguageCode')">
                                        🔊 Nghe thử
                                    </button>
                                    <button type="button" class="btn-assign" style="background: #94a3b8; color: white; border: none;" onclick="stopSpeaking()">
                                        ⏹
                                    </button>
                                    <form method="post" asp-page-handler="Assign" class="assign-form">
                                        <input type="hidden" name="audioId" value="@a.Id" />
                                        <select name="restaurantId">
                                            <option value="0">-- Bỏ gắn --</option>
                                            @foreach (var r in Model.Restaurants)
                                            {
                                                <option value="@r.Id" selected="@(a.RestaurantId == r.Id)">@r.Name</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn-assign">📍 Lưu địa điểm</button>
                                    </form>

                                    <a href="/Audio?id=@a.Id&mode=edit" class="btn-assign" style="text-decoration:none">✏️ Sửa</a>

                                    <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Xóa kịch bản này?')">
                                        <input type="hidden" name="id" value="@a.Id" />
                                        <button type="submit" class="btn-delete">🗑 Xóa</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <script>
        // Tự động cập nhật char count khi trang vừa load (nếu đang sửa)
        window.onload = function() {
            updateCount(document.getElementById('textInput'));
        };

        function updateCount(el) {
            if(el) document.getElementById('charCount').textContent = el.value.length;
        }

            // Hàm dừng thuyết minh ngay lập tức
        function stopSpeaking() {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel();
                console.log("Đã dừng thuyết minh.");
            }
        }

        // Cập nhật lại hàm previewText một chút để mượt mà hơn
        function previewText(elementId, isRawText = false, selectId = null, directLang = null) {
            let text = "";
            if(isRawText){
                const el = document.getElementById(elementId);
                text = el ? el.innerText.replace(/^"|"$/g, '') : "";
            } else {
                const el = document.getElementById(elementId);
                text = el ? el.value : "";
            }

            if (!text || text.trim() === "") {
                alert("Vui lòng nhập nội dung để nghe thử!");
                return;
            }

            let lang = 'vi-VN';
            if (directLang) {
                lang = directLang;
            } else if (selectId) {
                lang = document.getElementById(selectId).value;
            }

            // Dừng bất kỳ âm thanh nào đang phát trước khi phát cái mới
            window.speechSynthesis.cancel();

            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = lang;
            utterance.rate = 1.0;

            // Có thể thêm log để kiểm tra trạng thái
            utterance.onstart = () => console.log("Bắt đầu đọc...");
            utterance.onend = () => console.log("Kết thúc đọc.");

            window.speechSynthesis.speak(utterance);
        }

            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = lang;
            utterance.rate = 1.0;
            window.speechSynthesis.speak(utterance);
        

        document.getElementById('ttsForm').addEventListener('submit', function (e) {
            const textInput = document.getElementById('textInput').value.trim();
            if (!textInput) {
                alert("Vui lòng nhập nội dung văn bản!");
                e.preventDefault();
                return;
            }
            const btn = document.getElementById('genBtn');
            const spinner = document.getElementById('spinner');
            const text = document.getElementById('genText');

            btn.disabled = true;
            spinner.style.display = 'inline-block';
            text.textContent = 'Đang xử lý...';
        });
    </script>
</body>
</html>