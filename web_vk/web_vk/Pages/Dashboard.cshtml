@page
@model web_vk.Pages.DashboardModel
@{
    Layout = null;
    var username = HttpContext.Session.GetString("user") ?? "Admin";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tổng quan – Vĩnh Khánh</title>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --sidebar-bg: #13151f;
            --sidebar-w: 260px;
            --accent: #c9a84c;
            --accent-hover: #b8923e;
            --text-muted: #8a8a9a;
            --header-h: 64px;
            --radius: 12px;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background: #0f1117;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ─── SIDEBAR ─── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            color: #fff;
            display: flex;
            flex-direction: column;
            height: 100vh;
            flex-shrink: 0;
        }

        .sidebar-brand {
            padding: 22px 20px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(201,168,76,.12);
        }

        .brand-icon {
            width: 38px;
            height: 38px;
            background: var(--accent);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .brand-text .name {
            font-weight: 700;
            font-size: 15px;
        }

        .brand-text .role {
            font-size: 10px;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .nav-section {
            padding: 20px 12px 6px;
        }

        .nav-label {
            font-size: 10px;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: 0 10px 8px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            color: #a89878;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: background .15s, color .15s;
        }

            .nav-link:hover {
                background: rgba(255,255,255,.07);
                color: #fff;
            }

            .nav-link.active {
                background: var(--accent);
                color: #fff;
            }

        .nav-icon {
            font-size: 16px;
            width: 20px;
            text-align: center;
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 12px;
            border-top: 1px solid rgba(201,168,76,.12);
        }

        .user-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            border-radius: 8px;
            background: rgba(255,255,255,.05);
            margin-bottom: 8px;
        }

        .avatar {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            background: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
        }

        .user-info .uname {
            font-size: 13px;
            font-weight: 600;
        }

        .user-info .urole {
            font-size: 11px;
            color: var(--text-muted);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            padding: 10px 12px;
            border-radius: 8px;
            background: rgba(255,255,255,.05);
            border: none;
            cursor: pointer;
            color: #c3cde6;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            transition: background .15s;
        }

            .logout-btn:hover {
                background: rgba(255,255,255,.1);
                color: #fff;
            }

        /* ─── MAIN ─── */
        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .topbar {
            height: var(--header-h);
            background: #13151f;
            border-bottom: 1px solid rgba(201,168,76,.15);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            flex-shrink: 0;
        }

            .topbar h1 {
                font-size: 18px;
                font-weight: 700;
                color: #e8e6df;
            }

        .status-pill {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: 13px;
            font-weight: 500;
            color: #16a34a;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 0 3px rgba(34,197,94,.2);
        }

        /* ─── CONTENT ─── */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 28px;
        }

        .welcome-banner {
            background: linear-gradient(135deg, #1c1503 0%, #2e2005 100%);
            border: 1px solid rgba(201,168,76,.25);
            border-radius: var(--radius);
            padding: 28px 32px;
            color: #fff;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

            .welcome-banner::after {
                content: '✈';
                position: absolute;
                right: 32px;
                top: 50%;
                transform: translateY(-50%);
                font-size: 80px;
                opacity: .08;
            }

            .welcome-banner h2 {
                font-size: 22px;
                font-weight: 700;
                margin-bottom: 4px;
            }

            .welcome-banner p {
                font-size: 14px;
                color: rgba(255,255,255,.65);
            }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: #13151f;
            border-radius: var(--radius);
            padding: 20px 22px;
            display: flex;
            align-items: center;
            gap: 16px;
            box-shadow: 0 1px 4px rgba(0,0,0,.3);
            border: 1px solid rgba(201,168,76,.1);
            transition: box-shadow .2s;
        }

            .stat-card:hover {
                box-shadow: 0 4px 20px rgba(201,168,76,.12);
            }

        .stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

            .stat-icon.blue {
                background: rgba(201,168,76,.15);
            }

            .stat-icon.green {
                background: rgba(201,168,76,.11);
            }

            .stat-icon.purple {
                background: rgba(201,168,76,.08);
            }

            .stat-icon.orange {
                background: rgba(201,168,76,.06);
            }

        .stat-val {
            font-size: 24px;
            font-weight: 700;
            color: #e8e6df;
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        /* Quick actions */
        .section-title {
            font-size: 15px;
            font-weight: 700;
            color: #e8e6df;
            margin-bottom: 14px;
        }

        .actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 14px;
        }

        .action-card {
            background: #13151f;
            border-radius: var(--radius);
            padding: 22px 20px;
            text-decoration: none;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
            box-shadow: 0 1px 4px rgba(0,0,0,.3);
            border: 1.5px solid rgba(201,168,76,.1);
            transition: border-color .2s, box-shadow .2s, transform .15s;
        }

            .action-card:hover {
                border-color: var(--accent);
                box-shadow: 0 6px 20px rgba(201,168,76,.2);
                transform: translateY(-2px);
            }

            .action-card .ac-icon {
                width: 40px;
                height: 40px;
                border-radius: 10px;
                background: rgba(201,168,76,.1);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 18px;
            }

            .action-card .ac-title {
                font-size: 14px;
                font-weight: 600;
                color: #e8e6df;
            }

            .action-card .ac-desc {
                font-size: 12px;
                color: var(--text-muted);
            }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">✈</div>
            <div class="brand-text">
                <div class="name">Vĩnh Khánh</div>
                <div class="role">Admin Dashboard</div>
            </div>
        </div>

        <div class="nav-section">
            <div class="nav-label">Tổng quan</div>
            <a href="/Dashboard" class="nav-link active">
                <span class="nav-icon">⊞</span> Tổng quan
            </a>
        </div>

        <div class="nav-section">
            <div class="nav-label">Quản lý nội dung</div>
            <a href="/Restaurants" class="nav-link">
                <span class="nav-icon">📍</span> Quản lý địa điểm
            </a>
            <a href="/Tours" class="nav-link">
                <span class="nav-icon">🔀</span> Quản lý Tour
            </a>
            <a href="/Audio" class="nav-link">
                <span class="nav-icon">🎧</span> Quản lý Audio
            </a>
            <a href="/Translations" class="nav-link">
                <span class="nav-icon">🌐</span> Bản dịch đa ngữ
            </a>
        </div>
        <div class="nav-section">
            <div class="nav-label">Người dùng</div>
            <a href="/UserManager" class="nav-link">
                <span class="nav-icon">👥</span> Quản lý User
            </a>
        </div>
       

        <div class="sidebar-footer">
            <div class="user-row">
                <div class="avatar">@username[0].ToString().ToUpper()</div>
                <div class="user-info">
                    <div class="uname">@username</div>
                    <div class="urole">Super Admin</div>
                </div>
            </div>
            <a href="/Login" class="logout-btn">
                <span>↪</span> Đăng xuất
            </a>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="main">
        <header class="topbar">
            <h1>Tổng quan</h1>
            <div style="display:flex; gap:20px; align-items:center">
                <div class="search-wrap">
                    <span class="search-ico">🔍</span>
                    <input placeholder="Tìm nhanh..." />
                </div>
                <div class="status-pill">
                    <div class="status-dot"></div>
                    Hệ thống ổn định
                </div>
            </div>
        </header>

        <div class="content">
            <div class="welcome-banner">
                <div>
                    <h2>Xin chào, @username 👋</h2>
                    <p>Hệ thống hiện đang quản lý dữ liệu cho ứng dụng thuyết minh Vĩnh Khánh.</p>
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">📍</div>
                    <div>
                        <div class="stat-val">@Model.TotalRestaurants</div>
                        <div class="stat-label">Địa điểm</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">🎧</div>
                    <div>
                        <div class="stat-val">@Model.TotalAudio</div>
                        <div class="stat-label">Audio</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">🔀</div>
                    <div>
                        <div class="stat-val">@Model.TotalTours</div>
                        <div class="stat-label">Tour hiện có</div>
                    </div>
                </div>
            </div>

            <div style="color: #e8e6df; font-weight:700; margin-bottom:15px">Truy cập nhanh</div>
            <div class="actions-grid">
                <a href="/Restaurants" class="action-card">
                    <div class="ac-title">📍 Địa điểm</div>
                    <div class="ac-desc">Cập nhật tọa độ & thông tin quán ăn</div>
                </a>
                <a href="/Audio" class="action-card">
                    <div class="ac-title">🎧 Audio</div>
                    <div class="ac-desc">Quản lý các file thuyết minh</div>
                </a>
                <a href="/Translations" class="action-card">
                    <div class="ac-title">🌐 Ngôn ngữ</div>
                    <div class="ac-desc">Bản dịch cho khách quốc tế</div>
                </a>
            </div>
        </div>
    </div>

</body>
</html>
